# Example Terraform variables for MX5 Alignment Infrastructure
# Copy this to terraform.tfvars and customize for your deployment

# AWS Configuration
aws_region = "us-east-1"
environment = "prod"

# S3 Bucket Configuration
# Leave empty to auto-generate from project name + account ID
bucket_name = ""

# Project naming
project_name = "mx5-alignment"
cloudfront_comment = "MX5 NC1 Wheel Alignment Tool - Production"

# Cache Configuration
cache_ttl_seconds = 3600  # 1 hour

# CloudFront Configuration
price_class = "PriceClass_100"  # Most regions, cost-effective

# Logging (optional)
enable_logging = false

# Versioning (for rollback capability)
enable_versioning = true

# Custom Domain (optional)
# Set these if you want a branded domain
custom_domain = ""  # e.g., "alignment.example.com"
acm_certificate_arn = ""  # e.g., "arn:aws:acm:us-east-1:123456789012:certificate/..."

# Local site directory
site_directory = "../site"
