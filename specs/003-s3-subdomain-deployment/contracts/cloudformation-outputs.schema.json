{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudFormation Template Outputs for S3 Subdomain Deployment",
  "description": "Output values provided by the CloudFormation stack after successful deployment",
  "type": "object",
  "properties": {
    "AppBucketName": {
      "type": "string",
      "description": "S3 bucket name where app files (site/) are stored. User uploads files to this bucket.",
      "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 63,
      "examples": ["alignment-example-com-123456789012"]
    },
    "CloudFrontDomainName": {
      "type": "string",
      "description": "CloudFront distribution domain name (d123abc.cloudfront.net). Can be used for temporary access before DNS propagates.",
      "pattern": "^[a-z0-9]+\\.cloudfront\\.net$",
      "examples": ["d123abc.cloudfront.net", "d1234567890.cloudfront.net"]
    },
    "DistributionId": {
      "type": "string",
      "description": "CloudFront distribution ID. Used for invalidation operations and updates.",
      "pattern": "^E[A-Z0-9]{13}$",
      "examples": ["E1234ABCD5678"]
    },
    "DeployedUrl": {
      "type": "string",
      "description": "Final FQDN where the app is accessible. Example: alignment.example.com",
      "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)*$",
      "examples": ["alignment.example.com", "app.mydomain.co.uk"]
    },
    "StackStatus": {
      "type": "string",
      "description": "CloudFormation stack status (for reference)",
      "enum": ["CREATE_IN_PROGRESS", "CREATE_COMPLETE", "CREATE_FAILED", "UPDATE_IN_PROGRESS", "UPDATE_COMPLETE", "UPDATE_FAILED", "DELETE_IN_PROGRESS", "DELETE_COMPLETE", "DELETE_FAILED"]
    }
  },
  "required": ["AppBucketName", "CloudFrontDomainName", "DistributionId", "DeployedUrl"],
  "additionalProperties": false,
  "examples": [
    {
      "AppBucketName": "alignment-example-com-123456789012",
      "CloudFrontDomainName": "d123abc.cloudfront.net",
      "DistributionId": "E1234ABCD5678",
      "DeployedUrl": "alignment.example.com",
      "StackStatus": "CREATE_COMPLETE"
    }
  ]
}
